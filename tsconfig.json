{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "target": "ES2020",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,

    "forceConsistentCasingInFileNames": true,
    "allowJs": false,
    "noEmitOnError": true
  },
  "include": ["src"]
}