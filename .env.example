# stream-api production environment — copy to .env on the server (Railway, VPS, etc.)

NODE_ENV=production
PORT=3003

# CORS — comma-separated frontend origins (required in production)
FRONTEND_ORIGIN=https://nskanime.uk,https://www.nskanime.uk

SENTRY_DSN=
ADMIN_TOKEN=change-me-in-production

# Optional: Redis / Upstash REST cache (episode + stream cache)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Or Upstash names:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Optional metadata (not required for streaming)
# TMDB_API_KEY=
# ANIDB_CLIENT=

# Provider (default: consumet-multi — do not change unless you know the stack)
# STREAM_PROVIDER=consumet-multi
# STREAM_PROVIDER_BASE_URL=
